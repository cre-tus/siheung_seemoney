<?xml version="1.0" encoding="utf-8"?>
<!--
  투표 카드 아이템 레이아웃.
  투표 전/후 View를 toggle하여 상태에 따라 다른 UI 표시.
  - viewVotingPanel  : 투표 전 (선택지 버튼)
  - viewResultPanel  : 투표 후 (결과 ProgressBar + 퍼센트)
-->
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- 투표 제목 -->
        <TextView
            android:id="@+id/tvPollTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/paperlogy_7bold"
            android:textColor="#111827"
            android:textSize="17sp"
            android:textStyle="bold" />

        <!-- 투표 설명 -->
        <TextView
            android:id="@+id/tvPollDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/paperlogy_4regular"
            android:textColor="#6B7280"
            android:textSize="13sp" />

        <!-- 마감일 + 참여자 수 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvPollDeadline"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/paperlogy_4regular"
                android:textColor="#9CA3AF"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvPollParticipants"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/paperlogy_5medium"
                android:textColor="#2563EB"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- 구분선 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="14dp"
            android:background="#F3F4F6" />

        <!-- ══════════════════════════════════════════
             투표 전 패널 (선택지 버튼 목록)
             투표 완료 시 GONE, 결과 패널 VISIBLE
             ══════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/viewVotingPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible">

            <!-- 선택지 버튼은 Adapter에서 동적으로 추가 -->
            <LinearLayout
                android:id="@+id/llOptions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <Button
                android:id="@+id/btnSubmitVote"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_button_blue"
                android:fontFamily="@font/paperlogy_6semibold"
                android:text="투표하기"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- ══════════════════════════════════════════
             투표 후 결과 패널 (퍼센트 + ProgressBar)
             투표 완료 시 VISIBLE, 그 전에는 GONE
             ══════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/viewResultPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- 내 선택 표시 -->
            <TextView
                android:id="@+id/tvMyVoteLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:fontFamily="@font/paperlogy_5medium"
                android:textColor="#2563EB"
                android:textSize="13sp" />

            <!-- 결과 행(Row)은 Adapter에서 동적으로 추가 -->
            <LinearLayout
                android:id="@+id/llResults"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
