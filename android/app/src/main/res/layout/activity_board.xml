<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    android:orientation="vertical">

    <!-- 상단 헤더 -->
    <include layout="@layout/include_header" />

    <!-- 기존 게시판 내용 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#F3F4F6"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 헤더 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#7C3AED"
                android:elevation="6dp"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/paperlogy_7bold"
                    android:text="💬 예산 제안 게시판"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/paperlogy_5medium"
                    android:text="시흥시 예산 사용에 대한 의견을 자유롭게 나눠보세요"
                    android:textColor="#EDE9FE"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- 글쓰기 버튼 -->
            <Button
                android:id="@+id/btnWrite"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="16dp"
                android:backgroundTint="#2563EB"
                android:fontFamily="@font/paperlogy_6semibold"
                android:text="+ 새 글쓰기"
                android:textColor="#FFFFFF" />

            <!-- 글쓰기 폼 -->
            <LinearLayout
                android:id="@+id/writeForm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_login_card"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="18dp"
                android:visibility="gone">

                <EditText
                    android:id="@+id/etTitle"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_login_input"
                    android:fontFamily="@font/paperlogy_5medium"
                    android:hint="제목을 입력하세요"
                    android:paddingHorizontal="14dp" />

                <EditText
                    android:id="@+id/etContent"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_login_input"
                    android:fontFamily="@font/paperlogy_5medium"
                    android:gravity="top"
                    android:hint="내용을 입력하세요"
                    android:padding="14dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnSubmit"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:backgroundTint="#2563EB"
                        android:fontFamily="@font/paperlogy_6semibold"
                        android:text="등록"
                        android:textColor="#FFFFFF" />

                    <Button
                        android:id="@+id/btnCancel"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:backgroundTint="#E5E7EB"
                        android:fontFamily="@font/paperlogy_6semibold"
                        android:text="취소"
                        android:textColor="#374151" />
                </LinearLayout>
            </LinearLayout>

            <!-- 인기 글 TOP 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="#FFF7ED"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/paperlogy_7bold"
                    android:text="📈 인기 글 TOP 3"
                    android:textColor="#9A3412"
                    android:textSize="17sp" />

                <LinearLayout
                    android:id="@+id/topContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical" />
            </LinearLayout>

            <!-- 게시글 목록 -->
            <LinearLayout
                android:id="@+id/postContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="vertical" />

        </LinearLayout>
    </ScrollView>

    <!-- 하단 네비 -->
    <include layout="@layout/include_bottom_nav" />

</LinearLayout>