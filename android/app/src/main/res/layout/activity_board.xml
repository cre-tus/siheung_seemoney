<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/bg_app" android:orientation="vertical">
    <include layout="@layout/include_header" />
    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/bg_purple_gradient" android:orientation="vertical" android:padding="20dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="☷  예산 제안 게시판" android:textColor="#FFFFFF" android:textSize="22sp" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="시흥시 예산 사용에 대한 의견을 자유롭게 나눠보세요" android:textColor="#F3E8FF" />
            </LinearLayout>
            <Button android:id="@+id/btnWritePost" android:layout_width="match_parent" android:layout_height="50dp" android:layout_marginTop="16dp" android:background="@drawable/bg_button_blue" android:text="＋ 새 글쓰기" android:textColor="#FFFFFF" android:textStyle="bold" />
            <LinearLayout android:id="@+id/layoutWriteForm" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:background="@drawable/bg_card" android:orientation="vertical" android:padding="20dp" android:visibility="gone">
                <EditText android:id="@+id/etPostTitle" android:layout_width="match_parent" android:layout_height="50dp" android:background="@drawable/bg_input" android:hint="제목을 입력하세요" android:padding="12dp" />
                <EditText android:id="@+id/etPostContent" android:layout_width="match_parent" android:layout_height="120dp" android:layout_marginTop="10dp" android:background="@drawable/bg_input" android:gravity="top" android:hint="내용을 입력하세요" android:padding="12dp" />
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:orientation="horizontal">
                    <Button android:id="@+id/btnSubmitPost" android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1" android:background="@drawable/bg_button_blue" android:text="등록" android:textColor="#FFFFFF" />
                    <Button android:id="@+id/btnCancelPost" android:layout_width="0dp" android:layout_height="44dp" android:layout_marginStart="8dp" android:layout_weight="1" android:background="@drawable/bg_button_gray" android:text="취소" android:textColor="#374151" />
                </LinearLayout>
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:background="@drawable/bg_orange_light" android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="↗ 인기 글 TOP 3" android:textColor="#9A3412" android:textStyle="bold" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:background="@drawable/bg_card" android:padding="12dp" android:text="1  학교 급식 품질 개선 예산 배정        ♥ 301" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:background="@drawable/bg_card" android:padding="12dp" android:text="2  시청 앞 공원 재정비 제안              ♥ 245" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:background="@drawable/bg_card" android:padding="12dp" android:text="3  청년 창업 지원 예산 확대 요청        ♥ 189" />
            </LinearLayout>
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:background="@drawable/bg_card" android:padding="20dp" android:text="시청 앞 공원 재정비 제안\n시청 앞 공원이 노후화되어 리모델링이 필요합니다. 어린이 놀이터와 운동시설을 추가하면 좋겠습니다.\n김시흥 · 2026.04.16\n\n♥ 245     💬 18" android:textColor="#111827" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:background="@drawable/bg_card" android:padding="20dp" android:text="청년 창업 지원 예산 확대 요청\n청년들의 창업을 돕기 위한 지원금과 교육 프로그램 예산을 늘려주세요.\n이청년 · 2026.04.15\n\n♥ 189     💬 24" android:textColor="#111827" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:background="@drawable/bg_card" android:padding="20dp" android:text="문화센터 야간 운영 건의\n직장인들도 이용할 수 있도록 문화센터를 저녁 9시까지 운영해주시면 좋겠습니다.\n박시민 · 2026.04.14\n\n♥ 132     💬 9" android:textColor="#111827" />
        </LinearLayout>
    </ScrollView>
    <include layout="@layout/include_bottom_nav" />
</LinearLayout>
