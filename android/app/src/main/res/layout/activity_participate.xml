<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    android:orientation="vertical">

    <include layout="@layout/include_header" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 참여 헤더 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_blue_gradient"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/paperlogy_7bold"
                    android:text="✓  시민 참여"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/paperlogy_4regular"
                    android:text="시흥시 예산 사용 방향을 결정하는데 참여하세요!"
                    android:textColor="#DBEAFE"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="@font/paperlogy_6semibold"
                    android:paddingTop="12dp"
                    android:text="✓ 참여 시 100 포인트 적립"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- 투표 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/paperlogy_7bold"
                    android:text="2027년 복지 예산 우선순위"
                    android:textColor="#111827"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/paperlogy_4regular"
                    android:text="내년도 복지 예산에서 가장 우선적으로 투자해야 할 분야를 선택해주세요."
                    android:textColor="#6B7280" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:fontFamily="@font/paperlogy_4regular"
                    android:text="마감: 2026.04.30     2,847명 참여"
                    android:textColor="#6B7280"
                    android:textSize="12sp" />

                <RadioGroup
                    android:id="@+id/rgPoll1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp">

                    <RadioButton
                        android:id="@+id/rbWelfareOld"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_card_border"
                        android:fontFamily="@font/paperlogy_5medium"
                        android:padding="12dp"
                        android:text="노인 복지" />

                    <RadioButton
                        android:id="@+id/rbWelfareYouth"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_card_border"
                        android:fontFamily="@font/paperlogy_5medium"
                        android:padding="12dp"
                        android:text="아동·청소년 복지" />

                    <RadioButton
                        android:id="@+id/rbWelfareDisabled"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_card_border"
                        android:fontFamily="@font/paperlogy_5medium"
                        android:padding="12dp"
                        android:text="장애인 복지" />
                </RadioGroup>

                <Button
                    android:id="@+id/btnVote1"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_button_blue"
                    android:fontFamily="@font/paperlogy_6semibold"
                    android:text="투표하기"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- 결과 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/paperlogy_7bold"
                    android:text="교통 인프라 개선 방향"
                    android:textColor="#111827"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/paperlogy_4regular"
                    android:text="시흥시 교통 개선을 위해 가장 필요한 사업은 무엇일까요?"
                    android:textColor="#6B7280" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:fontFamily="@font/paperlogy_4regular"
                    android:text="마감: 2026.05.15     3,521명 참여"
                    android:textColor="#6B7280"
                    android:textSize="12sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:fontFamily="@font/paperlogy_6semibold"
                    android:text="버스 노선 확충 ✓                               53.3%"
                    android:textStyle="bold" />

                <ProgressBar
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="28dp"
                    android:layout_marginTop="4dp"
                    android:max="100"
                    android:progress="53"
                    android:progressDrawable="@drawable/bg_progress_blue" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:fontFamily="@font/paperlogy_6semibold"
                    android:text="자전거 도로 확대                              26.8%"
                    android:textStyle="bold" />

                <ProgressBar
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="28dp"
                    android:layout_marginTop="4dp"
                    android:max="100"
                    android:progress="27"
                    android:progressDrawable="@drawable/bg_progress" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:fontFamily="@font/paperlogy_6semibold"
                    android:text="주차장 건설                                      19.9%"
                    android:textStyle="bold" />

                <ProgressBar
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="28dp"
                    android:layout_marginTop="4dp"
                    android:max="100"
                    android:progress="20"
                    android:progressDrawable="@drawable/bg_progress" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <include layout="@layout/include_bottom_nav" />
</LinearLayout>