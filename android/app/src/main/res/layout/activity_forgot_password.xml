<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_login_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="#33FFFFFF"
                android:gravity="center"
                android:text="←"
                android:textColor="#FFFFFF"
                android:textSize="22sp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvMainTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="비밀번호 찾기"
                    android:textColor="#FFFFFF"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="계정 비밀번호 재설정"
                    android:textColor="#DBEAFE"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- 진행 단계 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="20dp"
            android:orientation="horizontal">

            <View
                android:id="@+id/bar1"
                android:layout_width="0dp"
                android:layout_height="6dp"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:background="#FFFFFF" />

            <View
                android:id="@+id/bar2"
                android:layout_width="0dp"
                android:layout_height="6dp"
                android:layout_marginHorizontal="4dp"
                android:layout_weight="1"
                android:background="#55FFFFFF" />

            <View
                android:id="@+id/bar3"
                android:layout_width="0dp"
                android:layout_height="6dp"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:background="#55FFFFFF" />
        </LinearLayout>

        <!-- 카드 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_login_card"
            android:elevation="8dp"
            android:orientation="vertical"
            android:padding="22dp">

            <TextView
                android:id="@+id/tvStepTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="이메일 확인"
                android:textColor="#111827"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvStepDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="가입 시 사용한 이메일을 입력해주세요"
                android:textColor="#6B7280"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_error"
                android:padding="12dp"
                android:textColor="#DC2626"
                android:textSize="13sp"
                android:visibility="gone" />

            <!-- STEP 1 -->
            <LinearLayout
                android:id="@+id/layoutEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="등록된 이메일"
                    android:textColor="#111827"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_login_input"
                    android:hint="가입 시 사용한 이메일"
                    android:inputType="textEmailAddress"
                    android:maxLength="100"
                    android:paddingHorizontal="14dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="#FFFBEB"
                    android:padding="12dp"
                    android:text="📧 인증 코드 안내\n실제 이메일 발송은 서버가 필요합니다. 데모에서는 화면에 인증 코드를 표시합니다."
                    android:textColor="#92400E"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- STEP 2 -->
            <LinearLayout
                android:id="@+id/layoutVerify"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#EFF6FF"
                    android:gravity="center"
                    android:paddingTop="14dp"
                    android:text="🔑 데모 인증 코드"
                    android:textColor="#2563EB"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvDemoCode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#EFF6FF"
                    android:gravity="center"
                    android:paddingBottom="14dp"
                    android:text="000000"
                    android:textColor="#2563EB"
                    android:textSize="32sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvTimer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:gravity="end"
                    android:text="03:00"
                    android:textColor="#6B7280"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etVerifyCode"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_login_input"
                    android:gravity="center"
                    android:hint="000000"
                    android:inputType="number"
                    android:maxLength="6"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- STEP 3 -->
            <LinearLayout
                android:id="@+id/layoutReset"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="새 비밀번호"
                    android:textStyle="bold" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp">

                    <EditText
                        android:id="@+id/etNewPassword"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_login_input"
                        android:hint="••••••••"
                        android:inputType="textPassword"
                        android:paddingStart="14dp"
                        android:paddingEnd="60dp" />

                    <TextView
                        android:id="@+id/btnShowPassword"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:layout_gravity="end"
                        android:gravity="center"
                        android:paddingHorizontal="14dp"
                        android:text="보기"
                        android:textColor="#6B7280" />
                </FrameLayout>

                <TextView
                    android:id="@+id/tvLength"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="○ 8자 이상"
                    android:textColor="#9CA3AF"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvNumber"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="○ 숫자 포함"
                    android:textColor="#9CA3AF"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvSpecial"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="○ 특수문자 포함"
                    android:textColor="#9CA3AF"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvUpper"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="○ 영문 대문자 포함"
                    android:textColor="#9CA3AF"
                    android:textSize="12sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="새 비밀번호 확인"
                    android:textStyle="bold" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp">

                    <EditText
                        android:id="@+id/etConfirmPassword"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_login_input"
                        android:hint="••••••••"
                        android:inputType="textPassword"
                        android:paddingStart="14dp"
                        android:paddingEnd="60dp" />

                    <TextView
                        android:id="@+id/btnShowConfirm"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:layout_gravity="end"
                        android:gravity="center"
                        android:paddingHorizontal="14dp"
                        android:text="보기"
                        android:textColor="#6B7280" />
                </FrameLayout>

                <TextView
                    android:id="@+id/tvPasswordMatch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="#16A34A"
                    android:textSize="12sp"
                    android:visibility="gone" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="#F9FAFB"
                    android:padding="12dp"
                    android:text="DB 업데이트: password_hash, updated_at 필드가 갱신됩니다"
                    android:textColor="#6B7280"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- DONE -->
            <LinearLayout
                android:id="@+id/layoutDone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:background="#DCFCE7"
                    android:gravity="center"
                    android:text="✓"
                    android:textColor="#22C55E"
                    android:textSize="42sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="비밀번호 변경 완료"
                    android:textColor="#111827"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="새 비밀번호로 성공적으로 변경되었습니다."
                    android:textColor="#6B7280" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:background="#F9FAFB"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="계정 이메일"
                        android:textColor="#6B7280"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tvDoneEmail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="email@example.com"
                        android:textColor="#111827"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="updated_at"
                        android:textColor="#6B7280"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tvDoneUpdatedAt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2026.05.10"
                        android:textColor="#111827" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/btnResend"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:text="인증 코드 다시 받기"
                android:textColor="#2563EB"
                android:textStyle="bold"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnMain"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_button_blue"
                android:text="인증 코드 받기"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/btnLoginBottom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center"
            android:text="비밀번호가 기억나셨나요? 로그인"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>