<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    android:orientation="vertical">

    <include layout="@layout/include_header" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 예산 -->
            <LinearLayout
                android:id="@+id/cardBudgetTimer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_blue_gradient"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/paperlogy_5medium"
                    android:text="⏱  예산 (Budget)"
                    android:textColor="#DBEAFE"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <com.example.siheung_seemoney.ui.custom.AnimatedNumberTextView
                    android:id="@+id/tvBudgetAmount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/paperlogy_7bold"
                    android:text="1,600,000,000,000원"
                    android:textColor="#FFFFFF"
                    android:textSize="27sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/paperlogy_4regular"
                    android:text="서서히 감소 중..."
                    android:textColor="#DBEAFE"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- 부채 -->
            <LinearLayout
                android:id="@+id/cardDebtStopwatch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_red_gradient"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/paperlogy_5medium"
                    android:text="↗  부채 (Debt)"
                    android:textColor="#FEE2E2"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <com.example.siheung_seemoney.ui.custom.AnimatedNumberTextView
                    android:id="@+id/tvDebtAmount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/paperlogy_7bold"
                    android:text="120,000,000,000원"
                    android:textColor="#FFFFFF"
                    android:textSize="27sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/paperlogy_4regular"
                    android:text="지속적으로 증가 중..."
                    android:textColor="#FEE2E2"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- 예산 구조 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/paperlogy_7bold"
                    android:text="예산 사용 구조"
                    android:textColor="#1F2937"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:fontFamily="@font/paperlogy_6semibold"
                    android:text="복지                                           40%"
                    android:textColor="#374151"
                    android:textStyle="bold" />

                <ProgressBar
                    android:id="@+id/progressWelfare"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="10dp"
                    android:layout_marginTop="6dp"
                    android:max="100"
                    android:progress="40"
                    android:progressDrawable="@drawable/bg_progress_blue" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="@font/paperlogy_6semibold"
                    android:text="교통                                           25%"
                    android:textColor="#374151"
                    android:textStyle="bold" />

                <ProgressBar
                    android:id="@+id/progressTransport"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="10dp"
                    android:layout_marginTop="6dp"
                    android:max="100"
                    android:progress="25"
                    android:progressDrawable="@drawable/bg_progress_green" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="@font/paperlogy_6semibold"
                    android:text="환경                                           15%"
                    android:textColor="#374151"
                    android:textStyle="bold" />

                <ProgressBar
                    android:id="@+id/progressEnvironment"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="10dp"
                    android:layout_marginTop="6dp"
                    android:max="100"
                    android:progress="15"
                    android:progressDrawable="@drawable/bg_progress_orange" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="@font/paperlogy_6semibold"
                    android:text="기타                                           20%"
                    android:textColor="#374151"
                    android:textStyle="bold" />

                <ProgressBar
                    android:id="@+id/progressEtc"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="10dp"
                    android:layout_marginTop="6dp"
                    android:max="100"
                    android:progress="20"
                    android:progressDrawable="@drawable/bg_progress_purple" />
            </LinearLayout>

            <!-- 뉴스 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/paperlogy_7bold"
                    android:text="📰  재정 뉴스"
                    android:textColor="#111827"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/news1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_card_border"
                    android:fontFamily="@font/paperlogy_5medium"
                    android:padding="12dp"
                    android:text="시흥시 교통 예산 증가\n2026.04.15"
                    android:textColor="#111827" />

                <TextView
                    android:id="@+id/news2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_card_border"
                    android:fontFamily="@font/paperlogy_5medium"
                    android:padding="12dp"
                    android:text="복지 예산 확대 논의\n2026.04.14"
                    android:textColor="#111827" />

                <TextView
                    android:id="@+id/news3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_card_border"
                    android:fontFamily="@font/paperlogy_5medium"
                    android:padding="12dp"
                    android:text="환경 개선 사업 승인\n2026.04.13"
                    android:textColor="#111827" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <include layout="@layout/include_bottom_nav" />
</LinearLayout>