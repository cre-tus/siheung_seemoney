<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    android:orientation="vertical">

    <include layout="@layout/include_header" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 예산 -->
            <LinearLayout
                android:id="@+id/cardBudgetTimer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_blue_gradient"
                android:orientation="vertical"
                android:padding="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    
                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/paperlogy_5medium"
                        android:text="⏱  예산 (Budget)"
                        android:textColor="#DBEAFE"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvBudgetUnit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/paperlogy_4regular"
                        android:text="0.0조원"
                        android:textColor="#DBEAFE"
                        android:textSize="11sp" />
                </LinearLayout>

                <com.example.siheung_seemoney.ui.custom.AnimatedNumberTextView
                    android:id="@+id/tvBudgetAmount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/paperlogy_7bold"
                    android:text="1,600,000,000,000"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/paperlogy_4regular"
                    android:text="서서히 감소 중..."
                    android:textColor="#DBEAFE"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- 부채 -->
            <LinearLayout
                android:id="@+id/cardDebtStopwatch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_red_gradient"
                android:orientation="vertical"
                android:padding="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    
                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/paperlogy_5medium"
                        android:text="↗  부채 (Debt)"
                        android:textColor="#FEE2E2"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvDebtUnit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/paperlogy_4regular"
                        android:text="0.0조원"
                        android:textColor="#FEE2E2"
                        android:textSize="11sp" />
                </LinearLayout>

                <com.example.siheung_seemoney.ui.custom.AnimatedNumberTextView
                    android:id="@+id/tvDebtAmount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/paperlogy_7bold"
                    android:text="1,200,000,000,000"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/paperlogy_4regular"
                    android:text="지속적으로 증가 중..."
                    android:textColor="#FEE2E2"
                    android:textSize="12sp" />
            </LinearLayout>



            <!-- 뉴스 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/paperlogy_7bold"
                    android:text="📰  재정 뉴스"
                    android:textColor="#111827"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <!-- 동적 뉴스 리스트 (RecyclerView) -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvNews"
                    android:layout_width="match_parent"
                    android:layout_height="320dp"
                    android:layout_marginTop="12dp"
                    android:overScrollMode="never" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <include layout="@layout/include_bottom_nav" />
</LinearLayout>