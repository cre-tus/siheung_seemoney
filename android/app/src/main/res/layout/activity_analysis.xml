<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    android:orientation="vertical">

    <include layout="@layout/include_header" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/paperlogy_7_bold.ttf"
                    android:text="연도 선택"
                    android:textColor="#111827"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/year2022"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_button_gray"
                            android:fontFamily="@font/paperlogy_5_medium.ttf    "
                            android:gravity="center"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:text="2022년" />

                        <TextView
                            android:id="@+id/year2023"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_button_gray"
                            android:fontFamily="@font/paperlogy_5_medium.ttf"
                            android:gravity="center"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:text="2023년" />

                        <TextView
                            android:id="@+id/year2024"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_button_gray"
                            android:fontFamily="@font/paperlogy_5_medium.ttf"
                            android:gravity="center"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:text="2024년" />

                        <TextView
                            android:id="@+id/year2025"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/bg_button_gray"
                            android:fontFamily="@font/paperlogy_5_medium.ttf"
                            android:gravity="center"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:text="2025년" />

                        <TextView
                            android:id="@+id/year2026"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_button_blue"
                            android:fontFamily="@font/paperlogy_7_bold.ttf"
                            android:gravity="center"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:text="2026년"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold" />
                    </LinearLayout>
                </HorizontalScrollView>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/paperlogy_7_bold.ttf"
                    android:text="분야별 예산 상세"
                    android:textColor="#111827"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:fontFamily="@font/paperlogy_6_semi_bold.ttf"
                    android:text="● 복지\n2,093,649,200,000원                         40%  ↗ +5.2%"
                    android:textColor="#111827"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <ProgressBar
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="8dp"
                    android:max="100"
                    android:progress="40"
                    android:progressDrawable="@drawable/bg_progress_blue" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:fontFamily="@font/paperlogy_6_semi_bold.ttf"
                    android:text="● 교통\n1,308,530,750,000원                         25%  ↗ +8.1%"
                    android:textColor="#111827"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <ProgressBar
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="8dp"
                    android:max="100"
                    android:progress="25"
                    android:progressDrawable="@drawable/bg_progress_green" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:fontFamily="@font/paperlogy_6_semi_bold.ttf"
                    android:text="● 환경\n785,118,450,000원                           15%  ↘ -2.3%"
                    android:textColor="#111827"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <ProgressBar
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="8dp"
                    android:max="100"
                    android:progress="15"
                    android:progressDrawable="@drawable/bg_progress_orange" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:fontFamily="@font/paperlogy_6_semi_bold.ttf"
                    android:text="● 기타\n1,046,824,600,000원                         20%  ↗ +1.5%"
                    android:textColor="#111827"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <ProgressBar
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="8dp"
                    android:max="100"
                    android:progress="20"
                    android:progressDrawable="@drawable/bg_progress_purple" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/paperlogy_7_bold.ttf"
                    android:text="연도별 예산·부채 변화"
                    android:textColor="#111827"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_card_border"
                    android:fontFamily="@font/paperlogy_4_regular.ttf"
                    android:gravity="center"
                    android:text="LineChart 영역\n2022~2026 예산/부채 변화\nMPAndroidChart 또는 Custom View 연결"
                    android:textColor="#6B7280" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/paperlogy_7_bold.ttf"
                    android:text="분야별 예산 비교"
                    android:textColor="#111827"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_card_border"
                    android:fontFamily="@font/paperlogy_4_regular.ttf"
                    android:gravity="center"
                    android:text="BarChart 영역\n복지 / 교통 / 환경 / 기타\nMPAndroidChart 또는 Custom View 연결"
                    android:textColor="#6B7280" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <include layout="@layout/include_bottom_nav" />
</LinearLayout>